{
  "name": "@phobos-maptool/maptool",
  "version": "2.0.1-alpha.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "libs/lsx/*",
    "libs/phobos/*",
    "libs/phobos/trx/*"
  ],
  "scripts": {
    "lerna": "lerna",
    "build": "lerna run build",
    "build:map": "npm run build -w libs/trx-map",
    "build:models": "npm run build -w libs/models",
    "build:elements": "npm run build -w libs/phobos-elements",
    "build:protocol": "npm run build -w libs/protocol",
    "docker:build": "node scripts/docker-build.js",
    "k8s:deploy": "helm upgrade --install phobos-maptool ./k8s",
    "k8s:status": "helm status phobos-maptool",
    "release": "release-it --workspaces",
    "release:pre": "npm run release -- --preRelease=alpha --no-git --no-github",
    "mirrord:frontend": "mirrord exec --config-file .mirrord/mirrord.json --target deployment/phobos-maptool-deployment -- npm run start:frontend",
    "start:frontend": "npm run start -w apps/frontend",
    "start:frontend:dev": "npm run start:dev -w apps/frontend",
    "start:backend": "npm run start -w apps/backend",
    "start:backend:dev": "npm run start:dev -w apps/backend"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "lerna": "^9.0.7",
    "release-it": "^19.2.4"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it/schema/release-it.json",
    "github": {
      "release": true
    },
    "git": {
      "requireCleanWorkingDir": false
    },
    "npm": {
      "publish": false,
      "bump": false
    },
    "plugins": {
      "@release-it/bumper": {
        "out": [
          "apps/*/package.json",
          {
            "file": "k8s/Chart.yaml",
            "path": "version"
          },
          {
            "file": "k8s/Chart.yaml",
            "path": "appVersion"
          }
        ]
      }
    },
    "hooks": {
      "after:release": [
        "docker build -t prim/phobos-maptool:${version} -t prim/phobos-maptool:latest ."
      ]
    }
  }
}
