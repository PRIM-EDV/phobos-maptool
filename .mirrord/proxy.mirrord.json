{
    "accept_invalid_certificates": true,
    "feature": {
        "network": {
            "incoming": {
                "mode": "steal",
                "http_filter": {
                    "path_filter": ".*"
                }
            },
            "outgoing": {
                "filter": {
                    "local": ["127.0.0.1", "localhost", "4200"]
                }
            }
        },
        "fs": "local",
        "env": true
    }
}