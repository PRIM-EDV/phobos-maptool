    "accept_invalid_certificates": true,
    "feature": {
        "network": {
            "incoming": {
                "mode": "steal",
                "http_filter": {
                    "path_filter": "^/(?!api).*"
                },
                "port_mapping": [
                    [3002, 4002]
                ]
            }
        },
        "fs": "local",
        "env": true
    }
}